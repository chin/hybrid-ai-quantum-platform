{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optchin.dev/schemas/portfolio.schema.json",
  "title": "OptEngine bounded portfolio execution",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "problem", "execution"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Execution name used in the output filename."
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assets", "expected_returns", "covariance"],
      "properties": {
        "assets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_returns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          }
        },
        "covariance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "number"
            }
          }
        },
        "allocation_increment": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1,
          "default": 0.25
        },
        "risk_aversion": {
          "type": "number",
          "minimum": 0,
          "default": 0.5
        },
        "max_assets": {
          "type": ["integer", "null"],
          "minimum": 1,
          "default": null
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategies": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "render": {
          "type": "boolean",
          "default": true
        },
        "output_dir": {
          "type": "string",
          "minLength": 1,
          "default": "outputs"
        }
      }
    }
  }
}
